# Stripe API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs - Regular Ranks
STRIPE_PRICE_SHADOW_ENCHANTER=price_your_shadow_enchanter_price_id
STRIPE_PRICE_VOID_WALKER=price_your_void_walker_price_id
STRIPE_PRICE_ETHEREAL_WARDEN=price_your_ethereal_warden_price_id
STRIPE_PRICE_ASTRAL_GUARDIAN=price_your_astral_guardian_price_id

# Stripe Price IDs - Regular Rank Upgrades
STRIPE_PRICE_SHADOW_ENCHANTER_TO_VOID_WALKER=price_your_upgrade_price_id
STRIPE_PRICE_VOID_WALKER_TO_ETHEREAL_WARDEN=price_your_upgrade_price_id
STRIPE_PRICE_ETHEREAL_WARDEN_TO_ASTRAL_GUARDIAN=price_your_upgrade_price_id

# Stripe Price IDs - Towny Ranks
STRIPE_PRICE_CITIZEN=price_your_citizen_price_id
STRIPE_PRICE_MERCHANT=price_your_merchant_price_id
STRIPE_PRICE_COUNCILOR=price_your_councilor_price_id
STRIPE_PRICE_MAYOR=price_your_mayor_price_id
STRIPE_PRICE_GOVERNOR=price_your_governor_price_id
STRIPE_PRICE_NOBLE=price_your_noble_price_id
STRIPE_PRICE_DUKE=price_your_duke_price_id
STRIPE_PRICE_KING=price_your_king_price_id
STRIPE_PRICE_EMPEROR=price_your_emperor_price_id
STRIPE_PRICE_DIVINE=price_your_divine_price_id

# Stripe Price IDs - Towny Rank Upgrades
STRIPE_PRICE_CITIZEN_TO_MERCHANT=price_your_upgrade_price_id
STRIPE_PRICE_MERCHANT_TO_COUNCILOR=price_your_upgrade_price_id
STRIPE_PRICE_COUNCILOR_TO_MAYOR=price_your_upgrade_price_id
STRIPE_PRICE_MAYOR_TO_GOVERNOR=price_your_upgrade_price_id
STRIPE_PRICE_GOVERNOR_TO_NOBLE=price_your_upgrade_price_id
STRIPE_PRICE_NOBLE_TO_DUKE=price_your_upgrade_price_id
STRIPE_PRICE_DUKE_TO_KING=price_your_upgrade_price_id
STRIPE_PRICE_KING_TO_EMPEROR=price_your_upgrade_price_id
STRIPE_PRICE_EMPEROR_TO_DIVINE=price_your_upgrade_price_id

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Minecraft Server
MINECRAFT_SERVER_API_URL=http://your_minecraft_server:8080
MINECRAFT_SERVER_API_KEY=your_minecraft_api_key
MINECRAFT_PLUGIN_PATH=path/to/your/minecraft/plugins/WebsitePlugin

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# PostgreSQL connection details
POSTGRES_DATABASE=postgres
POSTGRES_HOST=your_postgres_host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_USER=postgres
POSTGRES_URL=your_postgres_connection_url
POSTGRES_URL_NON_POOLING=your_postgres_connection_url_non_pooling 